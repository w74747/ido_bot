# انسخ هذا الملف باسم .env واملأ القيم الحقيقية فيه (لا ترفع .env إلى GitHub)

# --- المصدر الرئيسي للـ IDOs (إلزامي) ---
CRYPTORANK_API_KEY=

# --- مصدر تكميلي اختياري لمشاريع IDO إضافية ---
ENABLE_COINMARKETCAP=false
COINMARKETCAP_API_KEY=

# --- مصادر المراحل المبكرة جداً (قبل الطرح العام) ---
# RootData: جولات تمويل RWA/Infra/DePIN/AI مبكرة (يحتاج مفتاح)
ENABLE_ROOTDATA=true
ROOTDATA_API_KEY=

# DefiLlama: endpoint /raises أصبح Pro tier مدفوع ($300/شهر)، المفتاح اختياري —
# إذا تركته فاضياً، يتم تخطي DefiLlama بهدوء بدل خطأ 402 متكرر
ENABLE_DEFILLAMA=true
DEFILLAMA_API_KEY=

# كم يوم للخلف تُعتبر فيه جولة التمويل "جديدة"
EARLY_STAGE_LOOKBACK_DAYS=30

# --- مزوّد نموذج اللغة ---
LLM_PROVIDER=together
TOGETHER_API_KEY=
TOGETHER_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# --- تلجرام ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- إعدادات التشغيل ---
POLL_INTERVAL_MINUTES=1440
PROCESSED_IDS_FILE=processed_projects.json
